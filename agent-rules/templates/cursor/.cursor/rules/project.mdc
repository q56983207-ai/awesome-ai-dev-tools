## Code Style

### TypeScript Conventions

```typescript
// Use explicit types, avoid any
const fetchData = async <T>(url: string): Promise<T> => {
  const response = await fetch(url);
  if (!response.ok) throw new Error(`HTTP ${response.status}`);
  return response.json();
};

// Prefer const, use readonly for immutable data
const config: Readonly<Config> = {
  apiUrl: process.env.API_URL,
  timeout: 5000,
};
```

### Component Structure

```tsx
// 1. Imports (external, then internal)
import React, { useState, useCallback } from 'react';
import { cn } from '@/lib/utils';
import { Button } from '../ui/Button';

// 2. Type definitions
interface UserCardProps {
  userId: string;
  className?: string;
}

// 3. Component definition
export function UserCard({ userId, className }: UserCardProps) {
  // Hooks first
  const [isLoading, setIsLoading] = useState(false);

  // Callbacks
  const handleClick = useCallback(() => {
    setIsLoading(true);
    // ...
  }, []);

  // Early returns
  if (!userId) return null;

  // Render
  return (
    <div className={cn('user-card', className)}>
      <Button onClick={handleClick} disabled={isLoading}>
        {isLoading ? 'Loading...' : 'Click me'}
      </Button>
    </div>
  );
}
```

### File Naming

| Type | Pattern | Example |
|------|---------|---------|
| Components | PascalCase.tsx | `UserCard.tsx` |
| Hooks | use{camelCase}.ts | `useAuth.ts` |
| Utils | camelCase.ts | `formatDate.ts` |
| Services | camelCase.ts | `apiClient.ts` |
| Types | camelCase.ts | `userTypes.ts` |
| Tests | Same as source + .test | `UserCard.test.tsx` |

